# WebSocket endpoint of the Colyseus server.
VITE_SERVER_URL=ws://localhost:2567

# Sentry DSN for client crash reporting. Leave unset to disable Sentry (e.g. in
# local dev). Safe to commit per-environment — a client DSN ships in the bundle.
VITE_SENTRY_DSN=

# --- Source map upload (build time only — see vite.config.ts) --------------
# Set SENTRY_AUTH_TOKEN in CI / Vercel to upload source maps on `vite build`, so
# production stack traces show original TS. It is a SECRET — do NOT prefix it
# with VITE_ (that would inline it into the public bundle). Unset = no upload.
# SENTRY_AUTH_TOKEN=
# Optional overrides if the defaults in vite.config.ts are wrong:
# SENTRY_ORG=game-fh
# SENTRY_PROJECT=game-client
