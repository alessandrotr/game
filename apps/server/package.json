{
  "name": "@arena/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "db:inspect": "tsx src/db/inspect.ts",
    "test": "vitest run",
    "typecheck": "tsc -b --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@arena/shared": "workspace:*",
    "@colyseus/core": "^0.15.17",
    "@colyseus/monitor": "^0.15.6",
    "@colyseus/schema": "^2.0.36",
    "@colyseus/ws-transport": "^0.15.3",
    "@dimforge/rapier3d-compat": "^0.14.0",
    "@sentry/node": "^10.57.0",
    "colyseus": "^0.15.17",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.10",
    "@types/pg": "^8.20.0",
    "pg-mem": "^3.0.14",
    "tsx": "^4.19.1",
    "vitest": "^2"
  }
