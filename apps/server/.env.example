# Copy to apps/server/.env to enable player persistence locally.
# Without DATABASE_URL the server runs fine, just without saving progression.

# Local Postgres (Homebrew or docker-compose):
DATABASE_URL=postgres://arena:arena@localhost:5432/arena
# A local instance doesn't use SSL — keep this for localhost:
PGSSL=disable

# Managed Postgres (Render/Neon/Supabase/etc.) — paste their connection string
# and remove PGSSL (managed DBs require SSL, which is the default):
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Production hardening (Phase 15) ---------------------------------------
# Restrict CORS to your client origin(s), comma-separated. Unset = allow all
# (fine for local dev). Set this in production.
# ALLOWED_ORIGINS=https://yourgame.com,https://www.yourgame.com

# Password for the /monitor ops dashboard (user: admin). In production the
# dashboard is DISABLED unless this is set; in dev it's open without it.
# MONITOR_PASSWORD=change-me

# Secret used to sign account session tokens (HMAC). MUST be set in production
# (≥16 chars) — otherwise tokens are signed with a random per-boot key and every
# restart logs all players out. Unset is fine for local dev.
# AUTH_SECRET=a-long-random-string
