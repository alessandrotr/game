{
  "name": "arena",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-based multiplayer arena RPG — pnpm monorepo (React Three Fiber client + Colyseus server).",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "pnpm --parallel --filter \"@arena/*\" run dev",
    "build": "pnpm --filter @arena/shared run build && pnpm --filter @arena/server run build && pnpm --filter @arena/client run build",
    "start": "pnpm --filter @arena/server run start",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,html,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,html,yaml,yml}\"",
    "clean": "pnpm -r exec rm -rf dist node_modules/.cache .turbo && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.9.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
